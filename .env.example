# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New dashboards: publishable key (optional if you still use anon below)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legacy name for the public anon JWT — used if publishable key is empty
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres for Drizzle + npm run db:seed — Supabase: click Connect (top of project) → Transaction pooler (6543)
# Use "Transaction pooler" URI (port 6543). Username MUST be postgres.your-project-ref — NOT plain "postgres".
# Example shape (replace host, user suffix, and password with yours from the dashboard):
# DATABASE_URL="postgresql://postgres.abcdefghijklmnop:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL=

# Site URL for auth email redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile (optional for local dev — use "placeholder" to skip verification)
TURNSTILE_SECRET_KEY=placeholder
NEXT_PUBLIC_TURNSTILE_SITE_KEY=placeholder

# Optional: protect GET /api/cron/live-sessions (Vercel Cron or external scheduler; Authorization: Bearer <secret>)
CRON_SECRET=
